# Reddit OAuth/Data API credentials for live fetch.
# Create an app at https://www.reddit.com/prefs/apps and choose "script" for local automation.
# Do not commit real secrets. Copy this file to .env or export these in your shell.

REDDIT_CLIENT_ID="your_reddit_app_client_id"
REDDIT_CLIENT_SECRET="your_reddit_app_client_secret"
REDDIT_USER_AGENT="Postmortem/0.1 by u/your_reddit_username"

# Required when config/config.yaml sets tts.provider: elevenlabs.
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
