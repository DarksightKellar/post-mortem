{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/episode_plan.schema.json",
  "title": "EpisodePlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_date",
    "title_angle",
    "cold_open",
    "segments",
    "outro"
  ],
  "properties": {
    "episode_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "title_angle": {
      "type": "string",
      "minLength": 1
    },
    "cold_open": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook", "visual_note"],
      "properties": {
        "hook": { "type": "string", "minLength": 1 },
        "visual_note": { "type": "string", "minLength": 1 }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_order",
          "reddit_post_id",
          "subreddit",
          "source_title",
          "setup_summary",
          "key_beats",
          "selected_comments",
          "host_angle",
          "host_2_mode",
          "visual_notes",
          "estimated_seconds"
        ],
        "properties": {
          "segment_order": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "reddit_post_id": {
            "type": "string",
            "minLength": 1
          },
          "subreddit": {
            "type": "string",
            "minLength": 1
          },
          "source_title": {
            "type": "string",
            "minLength": 1
          },
          "setup_summary": {
            "type": "string",
            "minLength": 1
          },
          "key_beats": {
            "type": "array",
            "minItems": 2,
            "maxItems": 6,
            "items": { "type": "string", "minLength": 1 }
          },
          "selected_comments": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["comment_id", "reason"],
              "properties": {
                "comment_id": { "type": "string", "minLength": 1 },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          },
          "host_angle": {
            "type": "string",
            "minLength": 1
          },
          "host_2_mode": {
            "type": "string",
            "enum": ["grounded", "adaptive"]
          },
          "visual_notes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "estimated_seconds": {
            "type": "integer",
            "minimum": 30,
            "maximum": 180
          }
        }
      }
    },
    "outro": {
      "type": "object",
      "additionalProperties": false,
      "required": ["callback", "tomorrow_tease", "visual_note"],
      "properties": {
        "callback": { "type": "string", "minLength": 1 },
        "tomorrow_tease": { "type": "string" },
        "visual_note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
